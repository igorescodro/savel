<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Ignore R generated classes -->
    <Match>
        <Class name="~.*\.R\$.*"/>
    </Match>
    <Match>
        <Class name="~.*\.Manifest\$.*"/>
    </Match>
    <!-- All bugs in test classes, except for JUnit-specific bugs -->
    <Match>
        <Class name="~.*\.*Test"/>
        <Not>
            <Bug code="IJU"/>
        </Not>
    </Match>
    <!-- Ignore Data Binding generated classes -->
    <Match>
        <Class name="~.*databinding.*"/>
    </Match>
    <!-- Ignore Realm generated classes -->
    <Match>
        <Class name="~io.realm.*"/>
    </Match>

</FindBugsFilter>
